### Java JDK jenv
eval "$(jenv init -)"

### Node.js NPM for FNM
eval "$(fnm env --use-on-cd --shell zsh)"

### pyenv
# Python 静态环境变量已迁移至 ~/.zprofile
# 部分镜像文件的校验和可能与官方不一致，跳过校验以避免安装中断
# export PYTHON_BUILD_MIRROR_URL_SKIP_CHECKSUM=1
# 初始化 pyenv (挂钩 Shell)
eval "$(pyenv init -)"
